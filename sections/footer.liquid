{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{% comment %}
  Section: GG Footer
  File: sections/footer.liquid
  Description: Full-brand GarageGains footer — brand column, two link-list columns,
               newsletter signup, social icons, payment icons, and policy links.
               Replaces the generic Dawn footer entirely.
{% endcomment %}

{%- liquid
  assign has_social = false
  if settings.social_instagram_link != blank or settings.social_facebook_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank
    assign has_social = true
  endif

  assign link_blocks = section.blocks | where: 'type', 'link_list'
  assign col2_block = link_blocks[0]
  assign col3_block = link_blocks[1]
-%}

<footer class="gg-footer" role="contentinfo">

  <!-- Ember accent line -->
  <div class="gg-footer__accent" aria-hidden="true"></div>

  <!-- Main grid -->
  <div class="gg-footer__inner">
    <div class="gg-footer__grid">

      <!-- ── COLUMN 1: BRAND ────────────────────────────── -->
      <div class="gg-footer__brand-col">

        <!-- Logo mark -->
        <a href="{{ routes.root_url }}" class="gg-logo" aria-label="{{ shop.name }} — home">
          <div class="gg-logo__mark" aria-hidden="true">GG</div>
          <div class="gg-logo__text">
            <div class="gg-logo__name">GARAGEGAINS</div>
            <div class="gg-logo__sub">REDEFINING PERFORMANCE</div>
          </div>
        </a>

        <!-- Brand tagline -->
        {%- if section.settings.tagline != blank -%}
          <p class="gg-footer__brand-desc">{{ section.settings.tagline }}</p>
        {%- endif -%}

        <!-- Social icons -->
        {%- if section.settings.show_social and has_social -%}
          <div class="gg-footer__social" aria-label="Social media links">

            {%- if settings.social_instagram_link != blank -%}
              <a
                href="{{ settings.social_instagram_link }}"
                class="gg-footer__social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GarageGains on Instagram"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" stroke-width="1.8" fill="none"/>
                  <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.8" fill="none"/>
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
                </svg>
              </a>
            {%- endif -%}

            {%- if settings.social_facebook_link != blank -%}
              <a
                href="{{ settings.social_facebook_link }}"
                class="gg-footer__social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GarageGains on Facebook"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M18 2H15C13.674 2 12.402 2.527 11.464 3.464C10.527 4.402 10 5.674 10 7V10H7V14H10V22H14V14H17L18 10H14V7C14 6.735 14.105 6.48 14.293 6.293C14.48 6.105 14.735 6 15 6H18V2Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                </svg>
              </a>
            {%- endif -%}

            {%- if settings.social_youtube_link != blank -%}
              <a
                href="{{ settings.social_youtube_link }}"
                class="gg-footer__social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GarageGains on YouTube"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z" stroke="currentColor" stroke-width="1.8" fill="none"/>
                  <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" fill="none"/>
                </svg>
              </a>
            {%- endif -%}

            {%- if settings.social_tiktok_link != blank -%}
              <a
                href="{{ settings.social_tiktok_link }}"
                class="gg-footer__social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GarageGains on TikTok"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- endif -%}

          </div>
        {%- endif -%}

      </div>
      <!-- ── END COLUMN 1 ────────────────────────────────── -->

      <!-- ── COLUMN 2: LINK LIST (Shop) ────────────────── -->
      {%- if col2_block != blank -%}
        <div class="gg-footer__nav-col" {{ col2_block.shopify_attributes }}>
          {%- if col2_block.settings.heading != blank -%}
            <h3 class="gg-footer__heading">{{ col2_block.settings.heading | escape }}</h3>
          {%- endif -%}
          {%- if col2_block.settings.menu != blank -%}
            <nav aria-label="{{ col2_block.settings.heading | escape }}">
              {%- for link in col2_block.settings.menu.links -%}
                <a
                  href="{{ link.url }}"
                  class="gg-footer__link{% if link.active %} gg-footer__link--active{% endif %}"
                >{{ link.title | escape }}</a>
              {%- endfor -%}
            </nav>
          {%- endif -%}
        </div>
      {%- endif -%}
      <!-- ── END COLUMN 2 ───────────────────────────────── -->

      <!-- ── COLUMN 3: LINK LIST (Help) ────────────────── -->
      {%- if col3_block != blank -%}
        <div class="gg-footer__nav-col" {{ col3_block.shopify_attributes }}>
          {%- if col3_block.settings.heading != blank -%}
            <h3 class="gg-footer__heading">{{ col3_block.settings.heading | escape }}</h3>
          {%- endif -%}
          {%- if col3_block.settings.menu != blank -%}
            <nav aria-label="{{ col3_block.settings.heading | escape }}">
              {%- for link in col3_block.settings.menu.links -%}
                <a
                  href="{{ link.url }}"
                  class="gg-footer__link{% if link.active %} gg-footer__link--active{% endif %}"
                >{{ link.title | escape }}</a>
              {%- endfor -%}
            </nav>
          {%- endif -%}
        </div>
      {%- endif -%}
      <!-- ── END COLUMN 3 ───────────────────────────────── -->

      <!-- ── COLUMN 4: NEWSLETTER ──────────────────────── -->
      {%- if section.settings.newsletter_enable -%}
        <div class="gg-footer__nl-col">

          {%- if section.settings.newsletter_heading != blank -%}
            <h3 class="gg-footer__heading">{{ section.settings.newsletter_heading }}</h3>
          {%- endif -%}

          {%- if section.settings.newsletter_subtext != blank -%}
            <p class="gg-footer__nl-sub">{{ section.settings.newsletter_subtext | escape }}</p>
          {%- endif -%}

          {%- form 'customer', id: 'ContactFooter', class: 'gg-footer__nl-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">

            <div class="gg-footer__input-wrap">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="gg-footer__input"
                value="{{ form.email }}"
                placeholder="your@email.com.au"
                aria-label="Email address"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                required
                {%- if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="ContactFooter-error"
                {%- elsif form.posted_successfully? %}
                  aria-describedby="ContactFooter-success"
                {%- endif %}
              >
            </div>

            <button
              type="submit"
              class="gg-btn gg-btn--primary gg-btn--sm gg-footer__submit"
              name="commit"
              aria-label="{{ section.settings.newsletter_button_label | escape }}"
            >
              <span class="gg-btn__label">{{ section.settings.newsletter_button_label | escape }}</span>
            </button>

            {%- if form.errors -%}
              <p class="gg-footer__form-msg gg-footer__form-msg--error" id="ContactFooter-error" role="alert">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}
              </p>
            {%- endif -%}

            {%- if form.posted_successfully? -%}
              <p class="gg-footer__form-msg gg-footer__form-msg--success" id="ContactFooter-success" tabindex="-1" autofocus>
                You're in. 10% off is on its way to your inbox.
              </p>
            {%- endif -%}

          {%- endform -%}

        </div>
      {%- endif -%}
      <!-- ── END COLUMN 4 ───────────────────────────────── -->

      <!-- Render any @app blocks passed in -->
      {%- for block in section.blocks -%}
        {%- if block.type == '@app' -%}
          <div {{ block.shopify_attributes }}>
            {% render block %}
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
    <!-- ── END GRID ───────────────────────────────────────── -->
  </div>

  <!-- ── BOTTOM BAR ─────────────────────────────────────── -->
  <div class="gg-footer__bottom">
    <div class="gg-footer__bottom-inner">

      <!-- Left: copyright + policy links -->
      <div class="gg-footer__left">
        <span class="gg-footer__copyright">
          &copy; {{ 'now' | date: '%Y' }} GarageGains. All rights reserved.
        </span>

        {%- if section.settings.show_policy and shop.policies.size > 0 -%}
          <div class="gg-footer__legal">
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <a href="{{ policy.url }}" class="gg-footer__policy-link">
                  {{ policy.title | escape }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Right: payment icons -->
      {%- if section.settings.payment_enable and shop.enabled_payment_types.size > 0 -%}
        <ul class="gg-footer__payments" role="list" aria-label="Accepted payment methods">
          {%- for type in shop.enabled_payment_types -%}
            <li>
              {{ type | payment_type_svg_tag: class: 'gg-footer__payment-icon' }}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

    </div>
  </div>
  <!-- ── END BOTTOM BAR ─────────────────────────────────── -->

</footer>

<style>
  /* ---- Footer accent line ---- */
  .gg-footer__accent {
    height: 2px;
    background: var(--ember);
  }

  /* ---- Brand column ---- */
  .gg-footer__brand-col {}

  /* ---- Social icons ---- */
  .gg-footer__social {
    display: flex;
    gap: 12px;
    margin-top: 20px;
  }

  .gg-footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: rgba(255,255,255,0.35);
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    text-decoration: none;
  }

  .gg-footer__social-link:hover {
    color: var(--bone);
    border-color: var(--ember);
    background: rgba(201,74,30,0.08);
  }

  /* ---- Newsletter column ---- */
  .gg-footer__nl-col {}

  .gg-footer__nl-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  /* Skewed email input */
  .gg-footer__input-wrap {
    display: block;
    transform: skewX(-20deg);
    overflow: hidden;
    border: 1px solid #333;
    height: 44px;
    width: 100%;
    background: #131313;
    transition: border-color 0.2s;
    margin-bottom: 10px;
  }

  .gg-footer__input-wrap:focus-within {
    border-color: var(--ember);
  }

  .gg-footer__input {
    display: block;
    width: 100%;
    height: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: var(--bone);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    padding: 0 20px;
    transform: skewX(20deg);
  }

  .gg-footer__input::placeholder {
    color: rgba(255,255,255,0.25);
  }

  /* Kill browser autofill white/yellow flash (WebKit/Blink/Samsung) */
  .gg-footer__input:-webkit-autofill,
  .gg-footer__input:-webkit-autofill:hover,
  .gg-footer__input:-webkit-autofill:focus,
  .gg-footer__input:-webkit-autofill:active {
    -webkit-box-shadow: 0 0 0 100px #131313 inset !important;
    -webkit-text-fill-color: var(--bone) !important;
    caret-color: var(--bone);
    transition: background-color 5000s ease-in-out 0s;
  }

  /* Firefox autofill dark-mode styling */
  .gg-footer__input {
    color-scheme: dark;
  }

  /* Kill Dawn/browser focus ring — visual focus is handled by
     .gg-footer__input-wrap:focus-within { border-color: ember } above */
  .gg-footer__input:focus {
    outline: none !important;
    box-shadow: none !important;
  }

  .gg-footer__submit {
    width: 100%;
    justify-content: center;
  }

  /* Form messages */
  .gg-footer__form-msg {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    margin-top: 8px;
    line-height: 1.5;
  }

  .gg-footer__form-msg--error {
    color: var(--ember);
  }

  .gg-footer__form-msg--success {
    color: #4ade80;
  }

  /* ---- Bottom bar ---- */
  .gg-footer__bottom {
    border-top: 1px solid var(--border);
    padding: 28px 32px;
  }

  .gg-footer__bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .gg-footer__left {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .gg-footer__copyright {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: rgba(255,255,255,0.3);
  }

  .gg-footer__legal {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .gg-footer__policy-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    transition: color 0.2s;
  }

  .gg-footer__policy-link:hover {
    color: var(--bone);
  }

  /* Payment icons */
  .gg-footer__payments {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .gg-footer__payment-icon {
    height: 24px;
    width: auto;
    opacity: 0.5;
    filter: grayscale(1);
    transition: opacity 0.2s, filter 0.2s;
  }

  .gg-footer__payment-icon:hover {
    opacity: 0.8;
    filter: grayscale(0);
  }

  /* ---- Active link state ---- */
  .gg-footer__link--active {
    color: var(--bone);
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .gg-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 36px;
    }

    .gg-footer__brand-col {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .gg-footer__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .gg-footer__bottom-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .gg-footer__bottom {
      padding: 28px 20px;
    }
  }
</style>

{% schema %}
{
  "name": "GG \u2014 Footer",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "Navigation column",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Column heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "Brand information",
      "settings": [
        {
          "type": "paragraph",
          "content": "Brand column is hardcoded in the footer. This block type is kept for compatibility."
        }
      ]
    },
    {
      "type": "text",
      "name": "Text block",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Our mission"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "label": "Content",
          "default": "<p>Commercial-grade gear. No commercial markup.</p>"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Commercial-grade equipment, without the commercial price tag. Built for hard-training Australians."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "GET 10% OFF YOUR FIRST ORDER"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Newsletter subtext",
      "default": "Join thousands of Australians training harder for less."
    },
    {
      "type": "text",
      "id": "newsletter_button_label",
      "label": "Subscribe button label",
      "default": "SUBSCRIBE"
    },
    {
      "type": "header",
      "content": "Social icons"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true,
      "info": "Social links are set in Theme settings > Social media."
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "label": "Show policy links",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Quick links",
          "menu": "footer"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Info",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}

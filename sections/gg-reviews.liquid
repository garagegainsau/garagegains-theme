<!-- ===========================
     Section: GG Reviews
     =========================== -->

<section class="gg-section" style="padding-top: 0;">
  <div class="gg-section__header">
    <div>
      <p class="section-label">{{ section.settings.eyebrow }}</p>
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>
    <div style="display:flex; align-items:center; gap:10px;">
      <span style="color:#F5A623; font-size:0.9rem;">★★★★★</span>
      <span style="font-size:0.82rem; color:var(--steel);">{{ section.settings.aggregate_rating }} from {{ section.settings.total_reviews }}</span>
    </div>
  </div>

  <div class="gg-reviews">
    {% for block in section.blocks %}
      {% if block.type == 'review' %}
        <div class="gg-review-card" {{ block.shopify_attributes }}>
          <div class="gg-review-card__stars">
            {% for i in (1..block.settings.stars) %}★{% endfor %}
          </div>
          <p class="gg-review-card__text">"{{ block.settings.text }}"</p>
          <div class="gg-review-card__footer">
            <span class="gg-review-card__name">{{ block.settings.name }}</span>
            <span class="gg-review-card__location">{{ block.settings.location }}</span>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "GG – Reviews",
  "settings": [
    { "type": "text", "id": "eyebrow",          "label": "Eyebrow",           "default": "Real Customers" },
    { "type": "text", "id": "title",            "label": "Title",             "default": "What They're Saying" },
    { "type": "text", "id": "aggregate_rating", "label": "Aggregate rating",  "default": "4.9 / 5" },
    { "type": "text", "id": "total_reviews",    "label": "Total reviews text", "default": "2,400+ reviews" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range",    "id": "stars",    "label": "Stars",    "min": 1, "max": 5, "default": 5 },
        { "type": "textarea", "id": "text",     "label": "Review text" },
        { "type": "text",     "id": "name",     "label": "Reviewer name",     "default": "Mitch T." },
        { "type": "text",     "id": "location", "label": "Reviewer location", "default": "Brisbane, QLD" }
      ]
    }
  ],
  "presets": [{
    "name": "GG – Reviews",
    "blocks": [
      { "type": "review", "settings": { "stars": 5, "name": "Mitch T.",  "location": "Brisbane, QLD",  "text": "Set up my full garage gym in a weekend. Quality is legit — feels like gear that'll last 20 years. Fast shipping too." } },
      { "type": "review", "settings": { "stars": 5, "name": "Sarah K.",  "location": "Melbourne, VIC", "text": "Finally a store that gets it — no fluff, straight-up solid equipment at prices that don't need a second mortgage." } },
      { "type": "review", "settings": { "stars": 5, "name": "Dave R.",   "location": "Perth, WA",      "text": "Power rack is rock solid. Cheaper than going to a commercial gym for a year. Couldn't be happier." } }
    ]
  }]
}
{% endschema %}

    },
    {
      "type": "text",
      "id": "headline_line3",
      "label": "Headline line 3 (optional)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Commercial-grade equipment, without the commercial price tag. Built for everyday Australians who train hard."
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary button text",
      "default": "EXPLORE GEAR"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button link"
    }
  ],
  "blocks": [
    {

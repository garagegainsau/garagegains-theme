          "default": "On all orders over $199"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GG \u2013 Hero",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "\ud83d\ude9a",
            "title": "FREE DELIVERY",
            "body": "On all orders over $199"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "\ud83d\udd04",
            "title": "30 DAY RETURNS",
            "body": "Easy, no-hassle returns"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "\ud83d\udee1\ufe0f",
            "title": "2-YEAR WARRANTY",
            "body": "On all equipment"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "\ud83d\udd12",

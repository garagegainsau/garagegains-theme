{% comment %}
  Section: GG Hero
  File: sections/gg-hero.liquid
  Description: Full-viewport hero — content anchored to bottom-left, image visible right side, TransformFitness-style
{% endcomment %}

<section class="gg-hero">

  <!-- Background image -->
  <div class="gg-hero__bg">
    {%- if section.settings.bg_image != blank -%}
      {{
        section.settings.bg_image
        | image_url: width: 2400, format: 'webp'
        | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            class: 'gg-hero__photo',
            alt: section.settings.bg_image.alt | default: 'GarageGains hero'
      }}
    {%- else -%}
      <div class="gg-hero__photo-placeholder"></div>
    {%- endif -%}
  </div>

  <!-- Left-to-right gradient overlay -->
  <div class="gg-hero__overlay"></div>

  <!-- Content — bottom-left anchored -->
  <div class="gg-hero__content">
    <div class="gg-hero__inner">

      <p class="gg-hero__eyebrow fu1">{{ section.settings.eyebrow }}</p>

      <h1 class="gg-hero__title fu2">
        {{ section.settings.headline_line1 }}<br>
        <span class="gg-hero__accent">{{ section.settings.headline_line2 }}</span>
        {%- if section.settings.headline_line3 != blank %}<br>{{ section.settings.headline_line3 }}{%- endif -%}
      </h1>

      <p class="gg-hero__body fu3">{{ section.settings.subheading }}</p>

      <div class="gg-hero__ctas fu4">
        <a href="{{ section.settings.cta_primary_url }}" class="gg-btn gg-btn--primary">
          <span class="gg-btn__label">{{ section.settings.cta_primary_text }} &nbsp;&rarr;</span>
          <div class="gg-btn__bg"></div>
          <div class="gg-btn__outline"></div>
        </a>
        <a href="{{ section.settings.cta_secondary_url }}" class="gg-btn gg-btn--secondary">
          <span class="gg-btn__label">{{ section.settings.cta_secondary_text }}</span>
          <div class="gg-btn__bg"></div>
          <div class="gg-btn__outline"></div>
        </a>
      </div>

    </div>
  </div>

</section>

<!-- Trust Bar -->
<div class="gg-trustbar">
  <div class="gg-trustbar__inner">
    {%- for block in section.blocks -%}
      {%- if block.type == 'trust_item' -%}
        <div class="gg-trustbar__item" {{ block.shopify_attributes }}>
          <span class="gg-trustbar__icon">{{ block.settings.icon }}</span>
          <div>
            <div class="gg-trustbar__title">{{ block.settings.title }}</div>
            <div class="gg-trustbar__body">{{ block.settings.body }}</div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<style>
  /* ---- Hero ---- */
  .gg-hero {
    position: relative;
    height: 100vh;
    min-height: 640px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .gg-hero__bg {
    position: absolute;
    inset: 0;
  }

  .gg-hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 65% center;
    display: block;
  }

  .gg-hero__photo-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
  }

  /* Dark on left so text is legible, fades right to reveal gym photo */
  .gg-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(10,10,10,0.97) 0%,
      rgba(10,10,10,0.88) 30%,
      rgba(10,10,10,0.45) 60%,
      rgba(10,10,10,0.08) 100%
    );
  }

  .gg-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .gg-hero__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 32px 80px;
    width: 100%;
  }

  .gg-hero__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ember);
    margin-bottom: 20px;
  }

  .gg-hero__title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(36px, 8vw, 88px);
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--bone);
    margin-bottom: 24px;
  }

  .gg-hero__accent { color: var(--ember); }

  .gg-hero__body {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 40px;
  }

  .gg-hero__ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* ---- Trust Bar ---- */
  .gg-trustbar {
    background: #0a0a0a;
    border-bottom: 1px solid #1a1a1a;
  }

  .gg-trustbar__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid #1a1a1a;
  }

  .gg-trustbar__item {
    padding: 24px 20px;
    border-right: 1px solid #1a1a1a;
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .gg-trustbar__item:last-child { border-right: none; }

  .gg-trustbar__icon {
    font-size: 20px;
    margin-top: 2px;
    flex-shrink: 0;
  }

  .gg-trustbar__title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bone);
    margin-bottom: 3px;
    line-height: 1.2;
  }

  .gg-trustbar__body {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    line-height: 1.4;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    .gg-hero__inner { padding: 100px 32px 72px; }
  }

  @media (max-width: 768px) {
    .gg-hero { height: 100svh; }
    .gg-hero__inner { padding: 80px 24px 60px; }
    .gg-hero__overlay {
      background: linear-gradient(
        to bottom,
        rgba(10,10,10,0.55) 0%,
        rgba(10,10,10,0.82) 55%,
        rgba(10,10,10,0.97) 100%
      );
    }
    .gg-trustbar__inner { grid-template-columns: repeat(2, 1fr); }
    .gg-trustbar__item { border-right: none; border-bottom: 1px solid #1a1a1a; }
    .gg-trustbar__item:nth-child(odd) { border-right: 1px solid #1a1a1a; }
    .gg-trustbar__item:last-child,
    .gg-trustbar__item:nth-last-child(2):nth-child(odd) { border-bottom: none; }
  }

  @media (max-width: 480px) {
    .gg-hero__inner { padding: 64px 20px 48px; }
    .gg-hero__body { font-size: 14px; }
    .gg-trustbar__inner { grid-template-columns: 1fr; }
    .gg-trustbar__item:nth-child(odd) { border-right: none; }
    .gg-trustbar__item { border-bottom: 1px solid #1a1a1a; }
    .gg-trustbar__item:last-child { border-bottom: none; }
  }
</style>

{% schema %}
{
  "name": "GG \u2013 Hero",
  "settings": [

{% comment %}
  Section: GG Hero
  File: sections/gg-hero.liquid
  Description: Full-viewport hero — content anchored to bottom-left, image visible right side, TransformFitness-style
{% endcomment %}

<section class="gg-hero">

  <!-- Background image -->
  <div class="gg-hero__bg">
    {%- if section.settings.bg_image != blank -%}
      {%- assign hero_alt = section.settings.bg_image.alt | default: 'GarageGains hero' -%}
      {{
        section.settings.bg_image
        | image_url: width: 2400, format: 'webp'
        | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            class: 'gg-hero__photo',
            alt: hero_alt
      }}
    {%- else -%}
      <img
        src="{{ 'gg-hero-bg.jpg' | asset_url }}"
        alt="GarageGains hero"
        class="gg-hero__photo"
        loading="eager"
        fetchpriority="high"
        width="2400"
      >
    {%- endif -%}
  </div>

  <!-- Left-to-right gradient overlay -->
  <div class="gg-hero__overlay"></div>

  <!-- Content — bottom-left anchored -->
  <div class="gg-hero__content">
    <div class="gg-hero__inner">

      <p class="gg-hero__eyebrow fu1">{{ section.settings.eyebrow }}</p>

      <h1 class="gg-hero__title fu2">
        {{ section.settings.headline_line1 }}<br>
        <span class="gg-hero__accent">{{ section.settings.headline_line2 }}</span>
        {%- if section.settings.headline_line3 != blank %}<br>{{ section.settings.headline_line3 }}{%- endif -%}
      </h1>

      <p class="gg-hero__body fu3">{{ section.settings.subheading }}</p>

      <div class="gg-hero__ctas fu4">
        <a href="{{ section.settings.cta_primary_url }}" class="gg-btn gg-btn--primary">
          <span class="gg-btn__label">{{ section.settings.cta_primary_text }} &nbsp;&rarr;</span>
          <div class="gg-btn__bg"></div>
          <div class="gg-btn__outline"></div>
        </a>
        <a href="{{ section.settings.cta_secondary_url }}" class="gg-btn gg-btn--secondary">
          <span class="gg-btn__label">{{ section.settings.cta_secondary_text }}</span>
          <div class="gg-btn__bg"></div>
          <div class="gg-btn__outline"></div>
        </a>
      </div>

    </div>
  </div>

</section>


<style>
  /* ---- Hero ---- */
  .gg-hero {
    position: relative;
    height: calc(100vh - 56px);
    min-height: 580px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .gg-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .gg-hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 65% 40%;
    display: block;
  }

  .gg-hero__photo-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
  }

  /* Dark overlay so text stays legible */
  .gg-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0,0,0,0.60);
  }

  .gg-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0,0,0,0.60);
    pointer-events: none;
  }

  .gg-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .gg-hero__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 32px 80px;
    width: 100%;
  }

  .gg-hero__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ember);
    margin-bottom: 20px;
  }

  .gg-hero__title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(36px, 8vw, 88px);
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--bone);
    margin-bottom: 24px;
  }

  .gg-hero__accent { color: var(--ember); }

  .gg-hero__body {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 40px;
  }

  .gg-hero__ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    .gg-hero__inner { padding: 100px 32px 72px; }
  }

  @media (max-width: 768px) {
    .gg-hero {
      height: 88svh;
      min-height: 520px;
      align-items: flex-end;
    }
    /* Zoom image in tighter — better portrait framing */
    .gg-hero__photo {
      object-position: 60% 15%;
      transform: scale(2.2);
      transform-origin: 62% 12%;
    }
    .gg-hero__inner {
      padding: 0 24px 52px;
      text-align: left;
    }
    /* Larger headline on mobile — desktop clamp max unchanged */
    .gg-hero__title {
      font-size: clamp(52px, 14vw, 72px);
      margin-bottom: 14px;
    }
    .gg-hero__body {
      font-size: 14px;
      margin-bottom: 28px;
      max-width: 100%;
    }
    .gg-hero__overlay { background: rgba(0,0,0,0.60); }
    /* Smaller CTA buttons — hero only, desktop unaffected */
    .gg-hero .gg-btn {
      height: 42px !important;
      padding: 0 22px !important;
    }
    .gg-hero .gg-btn .gg-btn__label {
      font-size: 12px !important;
      letter-spacing: 0.12em !important;
    }
  }

  @media (max-width: 480px) {
    .gg-hero__inner { padding: 0 20px 44px; }
    .gg-hero__title { font-size: clamp(48px, 13vw, 64px); }
  }
</style>


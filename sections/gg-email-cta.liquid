{% comment %}
  Section: GG Email CTA
  File: sections/gg-email-cta.liquid
  Description: Email signup section with large headline, Shopify native newsletter form, and skewed submit button
{% endcomment %}

<div class="gg-cta-section">
  <!-- Background image -->
  <div class="gg-cta-section__bg" aria-hidden="true">
    <img src="{{ 'morgans-catalogue.jpg' | asset_url }}" alt="" loading="lazy">
  </div>
  <!-- Dark overlay -->
  <div class="gg-cta-section__overlay" aria-hidden="true"></div>
  <!-- Animated ember glow orbs -->
  <div class="gg-cta-section__glow gg-cta-section__glow--1" aria-hidden="true"></div>
  <div class="gg-cta-section__glow gg-cta-section__glow--2" aria-hidden="true"></div>
  <div class="gg-cta-section__glow gg-cta-section__glow--3" aria-hidden="true"></div>
  <div class="gg-cta-section__inner">

    {%- if section.settings.eyebrow != blank -%}
      <span class="gg-sec-head__label" style="margin-bottom:20px;">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <h2 class="gg-cta-section__title">
      {{ section.settings.headline }}<br>
      {%- if section.settings.headline_accent != blank -%}
        <span>{{ section.settings.headline_accent }}</span>
      {%- endif -%}
    </h2>

    {%- if section.settings.body != blank -%}
      <p class="gg-cta-section__body">{{ section.settings.body }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'gg-email-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="gg-cta-form">
        <div class="gg-cta-input-wrap">
          <input
            class="gg-cta-input"
            type="email"
            name="contact[email]"
            placeholder="{{ section.settings.input_placeholder }}"
            autocomplete="email"
            required
          >
        </div>
        <button type="submit" class="gg-btn gg-btn--primary">
          <span class="gg-btn__label">{{ section.settings.cta_text }}</span>
          <div class="gg-btn__bg"></div>
          <div class="gg-btn__outline"></div>
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p style="color:#4ade80; font-family:'DM Sans',sans-serif; font-size:14px; margin-top:16px; text-align:center;">
          &#10003; You&rsquo;re in! Check your inbox for your discount code.
        </p>
      {%- endif -%}
      {%- if form.errors -%}
        <p style="color:#f87171; font-family:'DM Sans',sans-serif; font-size:14px; margin-top:16px; text-align:center;">
          {{ form.errors.translated_fields | join: ', ' | capitalize }} {{ form.errors.messages['email'] }}
        </p>
      {%- endif -%}
    {%- endform -%}

  </div>
</div>

<style>
  .gg-cta-section {
    position: relative;
    overflow: hidden;
  }

  /* Background image */
  .gg-cta-section__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .gg-cta-section__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
    filter: grayscale(40%) contrast(1.1);
  }

  /* Dark overlay so text stays legible */
  .gg-cta-section__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0,0,0,0.58);
  }

  /* Ensure content sits above everything */
  .gg-cta-section__inner {
    position: relative;
    z-index: 3;
  }

  /* Shared glow orb styles — radial-gradient fades to transparent,
     avoids overflow:hidden clipping that kills filter:blur() orbs */
  .gg-cta-section__glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 2;
  }

  /* Orb 1 — large left glow */
  .gg-cta-section__glow--1 {
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(201,74,30,0.85) 0%, rgba(201,74,30,0.4) 35%, transparent 70%);
    top: -200px;
    left: -150px;
    animation: gg-glow-drift-1 14s ease-in-out infinite alternate;
  }

  /* Orb 2 — large right glow */
  .gg-cta-section__glow--2 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(201,74,30,0.75) 0%, rgba(201,74,30,0.3) 35%, transparent 70%);
    bottom: -180px;
    right: -120px;
    animation: gg-glow-drift-2 18s ease-in-out infinite alternate;
  }

  /* Orb 3 — centre pulse */
  .gg-cta-section__glow--3 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(224,85,36,0.55) 0%, transparent 65%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: gg-glow-pulse 9s ease-in-out infinite;
  }

  @keyframes gg-glow-drift-1 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(220px, 80px) scale(1.15); }
  }

  @keyframes gg-glow-drift-2 {
    from { transform: translate(0, 0) scale(1.1); }
    to   { transform: translate(-180px, -60px) scale(0.9); }
  }

  @keyframes gg-glow-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1);    opacity: 0.08; }
    50%       { transform: translate(-50%, -50%) scale(1.4); opacity: 0.14; }
  }
</style>

{% schema %}
{
  "name": "GG \u2013 Email CTA",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Limited Time"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "GET 10% OFF"
    },
    {
      "type": "text",
      "id": "headline_accent",
      "label": "Headline accent (ember colour)",
      "default": "YOUR FIRST ORDER"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Join the GarageGains community. Sign up and receive 10% off your first order, plus early access to new products and exclusive deals."
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Email input placeholder",
      "default": "your@email.com.au"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Claim 10% Off"
    }
  ],
  "presets": [
    {
      "name": "GG \u2013 Email CTA"
    }
  ]
}
{% endschema %}

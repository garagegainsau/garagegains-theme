{% comment %}
  Section: GG Email CTA
  File: sections/gg-email-cta.liquid
  Description: Email signup section with large headline, Shopify native newsletter form, and skewed submit button
{% endcomment %}

<div class="gg-cta-section">
  <div class="gg-cta-section__inner">

    {%- if section.settings.eyebrow != blank -%}
      <span class="gg-sec-head__label" style="margin-bottom:20px;">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <h2 class="gg-cta-section__title">
      {{ section.settings.headline }}<br>
      {%- if section.settings.headline_accent != blank -%}
        <span>{{ section.settings.headline_accent }}</span>
      {%- endif -%}
    </h2>

    {%- if section.settings.body != blank -%}
      <p class="gg-cta-section__body">{{ section.settings.body }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'gg-email-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="gg-cta-form">
        <input
          class="gg-cta-input"
          type="email"
          name="contact[email]"
          placeholder="{{ section.settings.input_placeholder }}"
          autocomplete="email"
          required
        >
        <button type="submit" class="gg-btn gg-btn--primary">
          <span class="gg-btn__label">{{ section.settings.cta_text }}</span>
          <div class="gg-btn__bg"></div>
          <div class="gg-btn__outline"></div>
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p style="color:#4ade80; font-family:'DM Sans',sans-serif; font-size:14px; margin-top:16px; text-align:center;">
          &#10003; You&rsquo;re in! Check your inbox for your discount code.
        </p>
      {%- endif -%}
      {%- if form.errors -%}
        <p style="color:#f87171; font-family:'DM Sans',sans-serif; font-size:14px; margin-top:16px; text-align:center;">
          {{ form.errors.translated_fields | join: ', ' | capitalize }} {{ form.errors.messages['email'] }}
        </p>
      {%- endif -%}
    {%- endform -%}

  </div>
</div>

{% schema %}
{
  "name": "GG \u2013 Email CTA",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Limited Time"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "GET 10% OFF"
    },
    {
      "type": "text",
      "id": "headline_accent",
      "label": "Headline accent (ember colour)",
      "default": "YOUR FIRST ORDER"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Join the GarageGains community. Sign up and receive 10% off your first order, plus early access to new products and exclusive deals."
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Email input placeholder",
      "default": "your@email.com.au"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Claim 10% Off"
    }
  ],
  "presets": [
    {
      "name": "GG \u2013 Email CTA"
    }
  ]
}
{% endschema %}

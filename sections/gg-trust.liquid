<!-- ===========================
     Section: GG Trust Badges
     =========================== -->

<section class="gg-section" style="padding-top: 0;">
  {% if section.settings.show_heading %}
    <div style="text-align:center; margin-bottom:36px;">
      <p class="section-label">{{ section.settings.eyebrow }}</p>
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>
  {% endif %}

  <div class="gg-trust">
    {% for block in section.blocks %}
      {% if block.type == 'trust_item' %}
        <div class="gg-trust-item" {{ block.shopify_attributes }}>
          <div class="gg-trust-item__icon">{{ block.settings.icon }}</div>
          <div>
            <div class="gg-trust-item__title">{{ block.settings.title }}</div>
            <div class="gg-trust-item__body">{{ block.settings.body }}</div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "GG – Trust Badges",
  "settings": [
    { "type": "checkbox", "id": "show_heading", "label": "Show heading",  "default": true },
    { "type": "text",     "id": "eyebrow",      "label": "Eyebrow",       "default": "Why GarageGains" },
    { "type": "text",     "id": "title",        "label": "Title",         "default": "Built On Trust" }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        { "type": "text",     "id": "icon",  "label": "Emoji icon",  "default": "🚚" },
        { "type": "text",     "id": "title", "label": "Title",       "default": "Free Shipping Over $199" },
        { "type": "textarea", "id": "body",  "label": "Description", "default": "Fast Australia-wide delivery from our Sydney & Melbourne warehouses." }
      ]
    }
  ],
  "presets": [{
    "name": "GG – Trust Badges",
    "blocks": [
      { "type": "trust_item", "settings": { "icon": "🚚", "title": "Free Shipping Over $199",  "body": "Fast Australia-wide delivery from our Sydney & Melbourne warehouses." } },
      { "type": "trust_item", "settings": { "icon": "🛡️", "title": "2-Year Warranty",          "body": "Every piece of equipment backed by a full two-year warranty." } },
      { "type": "trust_item", "settings": { "icon": "💬", "title": "Real Human Support",       "body": "Aussie-based team ready to help Mon–Fri, 9am–5pm AEST." } },
      { "type": "trust_item", "settings": { "icon": "🔄", "title": "30-Day Returns",           "body": "Not happy? We'll sort it. Simple, no-hassle returns every time." } }
    ]
  }]
}
{% endschema %}

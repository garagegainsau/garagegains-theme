{% comment %}
  Section: GG Ticker Banner
  File: sections/gg-ticker.liquid
  Description: CSS-only infinite marquee ticker in ember background — no JavaScript required
{% endcomment %}

{%- assign ticker_items = section.settings.ticker_text | split: ',' -%}

<div class="gg-ticker">
  <div class="gg-ticker__track">
    {%- comment -%} First copy {%- endcomment -%}
    {%- for item in ticker_items -%}
      <span class="gg-ticker__item">{{ item | strip }}</span>
    {%- endfor -%}
    {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
    {%- for item in ticker_items -%}
      <span class="gg-ticker__item">{{ item | strip }}</span>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "GG \u2013 Ticker Banner",
  "settings": [
    {
      "type": "textarea",
      "id": "ticker_text",
      "label": "Ticker items (comma separated)",
      "default": "RACKS, BARBELLS, PLATES, BENCHES, DUMBBELLS, KETTLEBELLS, FLOORING, CARDIO, PULL-UP BARS"
    }
  ],
  "presets": [
    {
      "name": "GG \u2013 Ticker Banner"
    }
  ]
}
{% endschema %}

{% comment %}
  Section: GG Categories
  File: sections/gg-categories.liquid
  Description: Shop by category — full-bleed image cards with overlay name and badge
{% endcomment %}

<section class="gg-section gg-categories">

  <div class="gg-sec-head">
    <span class="gg-sec-head__label">{{ section.settings.eyebrow }}</span>
    <h2 class="gg-sec-head__title">{{ section.settings.title }}</h2>
  </div>

  <div class="gg-cat-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        <a href="{{ block.settings.url }}" class="gg-cat-card" {{ block.shopify_attributes }}>

          <!-- Image or emoji fallback -->
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 900, format: 'webp'
              | image_tag:
                  loading: 'lazy',
                  alt: block.settings.name,
                  class: 'gg-cat-card__img'
            }}
          {%- else -%}
            <div class="gg-cat-card__fallback">{{ block.settings.emoji }}</div>
          {%- endif -%}

          <!-- Gradient overlay -->
          <div class="gg-cat-card__overlay"></div>

          <!-- Badge -->
          {%- if block.settings.tag != blank -%}
            <span class="gg-cat-card__badge">{{ block.settings.tag }}</span>
          {%- endif -%}

          <!-- Bottom content -->
          <div class="gg-cat-card__content">
            <h3 class="gg-cat-card__name">{{ block.settings.name }}</h3>
            <span class="gg-cat-card__arrow">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>

        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.view_all_url != blank -%}
    <div style="text-align:center; margin-top:48px;">
      <a href="{{ section.settings.view_all_url }}" class="gg-btn gg-btn--secondary">
        <span class="gg-btn__label">View All Categories &rarr;</span>
        <div class="gg-btn__bg"></div>
        <div class="gg-btn__outline"></div>
      </a>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "GG \u2013 Categories",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Browse"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Shop By Category"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section description",
      "default": "Find the right equipment for your home gym setup."
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Category name",
          "default": "Power Racks"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Category link"
        },
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji fallback (if no image)",
          "default": "\ud83c\udfd7\ufe0f"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Badge label (optional)"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GG \u2013 Categories",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "name": "Power Racks & Cages",
            "emoji": "\ud83c\udfd7\ufe0f",
            "tag": "Most Popular",
            "description": "Commercial-gauge steel squat racks for every budget."
          }
        },
        {
          "type": "category",
          "settings": {
            "name": "Barbells & Weights",
            "emoji": "\ud83c\udfcb\ufe0f",
            "description": "Olympic and standard barbells, weight plates, and bumpers."
          }
        },
        {
          "type": "category",
          "settings": {
            "name": "Dumbbells & Kettlebells",
            "emoji": "\ud83d\udcaa",
            "tag": "New In",
            "description": "Fixed, adjustable, and hex dumbbells. Competition kettlebells."
          }
        },
        {
          "type": "category",
          "settings": {
            "name": "Benches",
            "emoji": "\ud83d\udecc",
            "description": "Flat, incline, and adjustable benches rated for heavy loads."
          }
        },
        {
          "type": "category",
          "settings": {
            "name": "Cardio",
            "emoji": "\ud83d\udeb4",
            "description": "Treadmills, rowers, assault bikes, and ski ergs."
          }
        },
        {
          "type": "category",
          "settings": {
            "name": "Mats & Flooring",
            "emoji": "\ud83d\udfe9",
            "tag": "Best Value",
            "description": "Rubber gym tiles, horse stall mats, and interlocking flooring."
          }
        }
      ]
    }
  ]
}
{% endschema %}

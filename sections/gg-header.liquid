{% comment %}
  Section: GG Header
  File: sections/gg-header.liquid
  Description: GarageGains sticky nav — hides on scroll down, reveals on scroll up
{% endcomment %}

<style>
  /* Unique to header — everything else is in assets/garagegains.css */
  .gg-nav.is-hidden { transform: translateY(-100%); }
  .gg-nav-spacer { height: 64px; }

  /* Drawer CTA — no skew, full-width, rounded */
  .gg-drawer__cta-wrap {
    display: block;
  }
  .gg-drawer__cta-wrap .gg-btn {
    width: 100%;
    height: 48px;
    transform: skewX(0deg) !important;
    border-radius: 4px !important;
  }
  .gg-drawer__cta-wrap .gg-btn .gg-btn__label {
    transform: skewX(0deg);
  }
</style>

<!-- ===================== HEADER ===================== -->
<header class="gg-nav" id="gg-nav" role="banner">
  <div class="gg-nav__inner">

    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="gg-logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo
          | image_url: width: 280, format: 'webp'
          | image_tag: loading: 'eager', alt: shop.name, style: 'height:34px;width:auto;display:block;'
        }}
      {%- else -%}
        <div class="gg-logo__mark">GG</div>
        <div>
          <div class="gg-logo__name">GarageGains</div>
          <div class="gg-logo__sub">Australia</div>
        </div>
      {%- endif -%}
    </a>

    <!-- Desktop nav links -->
    <nav class="gg-nav__links" aria-label="Main navigation">
      {%- assign nav_links = linklists[section.settings.menu].links -%}
      {%- if nav_links.size > 0 -%}
        {%- for link in nav_links -%}
          <a
            href="{{ link.url }}"
            class="gg-nav__link{% if link.title == 'Sale' or link.title == 'SALE' %} gg-nav__link--sale{% endif %}"
            {% if link.active %}aria-current="page"{% endif %}
          >{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/collections/strength"      class="gg-nav__link">Strength</a>
        <a href="/collections/cardio"        class="gg-nav__link">Cardio</a>
        <a href="/collections/functional"    class="gg-nav__link">Functional</a>
        <a href="/collections/commercial"    class="gg-nav__link">Commercial</a>
        <a href="/collections/flooring-mats" class="gg-nav__link">Flooring &amp; Mats</a>
        <a href="/collections/sale"          class="gg-nav__link gg-nav__link--sale">Sale</a>
        <a href="/pages/contact"             class="gg-nav__link">Contact</a>
      {%- endif -%}
    </nav>

    <!-- Desktop actions: search + account + cart + skewed CTA -->
    <div class="gg-nav__actions">
      <a href="{{ routes.search_url }}" class="gg-icon-btn" aria-label="Search">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </a>
      <a href="{{ routes.account_url }}" class="gg-icon-btn" aria-label="Account">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </a>
      <a href="{{ routes.cart_url }}" class="gg-icon-btn gg-cart-btn" aria-label="Cart ({{ cart.item_count }} items)">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="gg-cart-count" id="cart-count">{{ cart.item_count }}</span>
      </a>
      <a href="{{ section.settings.cta_url | default: routes.collections_url }}" class="gg-btn gg-btn--primary" style="height:40px;padding:0 22px;">
        <span class="gg-btn__label" style="font-size:13px;">{{ section.settings.cta_label | default: 'Shop Now' }}</span>
        <div class="gg-btn__bg"></div>
        <div class="gg-btn__outline"></div>
      </a>
    </div>

    <!-- Mobile: cart + burger -->
    <div class="gg-nav__mobile">
      <a href="{{ routes.cart_url }}" class="gg-icon-btn gg-cart-btn" aria-label="Cart">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="gg-cart-count">{{ cart.item_count }}</span>
      </a>
      <button
        class="gg-burger"
        id="gg-burger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="gg-drawer"
      >
        <span></span><span></span><span></span>
      </button>
    </div>

  </div>
</header>

<div class="gg-nav-spacer" aria-hidden="true"></div>

<!-- ===================== MOBILE DRAWER ===================== -->
<div class="gg-drawer" id="gg-drawer" role="dialog" aria-modal="true" aria-label="Navigation" aria-hidden="true">
  <div class="gg-drawer__backdrop" id="gg-backdrop"></div>
  <nav class="gg-drawer__panel">

    <div class="gg-drawer__head">
      <a href="{{ routes.root_url }}" class="gg-logo">
        <div class="gg-logo__mark">GG</div>
        <div>
          <div class="gg-logo__name">GarageGains</div>
          <div class="gg-logo__sub">Australia</div>
        </div>
      </a>
      <button class="gg-drawer__close" id="gg-drawer-close" aria-label="Close menu">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="gg-drawer__links">
      {%- assign nav_links = linklists[section.settings.menu].links -%}
      {%- if nav_links.size > 0 -%}
        {%- for link in nav_links -%}
          <a
            href="{{ link.url }}"
            class="gg-drawer__link{% if link.title == 'Sale' or link.title == 'SALE' %} gg-drawer__link--sale{% endif %}"
          >{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/collections/strength"      class="gg-drawer__link">Strength</a>
        <a href="/collections/cardio"        class="gg-drawer__link">Cardio</a>
        <a href="/collections/functional"    class="gg-drawer__link">Functional</a>
        <a href="/collections/commercial"    class="gg-drawer__link">Commercial</a>
        <a href="/collections/flooring-mats" class="gg-drawer__link">Flooring &amp; Mats</a>
        <a href="/collections/sale"          class="gg-drawer__link gg-drawer__link--sale">Sale</a>
        <a href="/pages/contact"             class="gg-drawer__link">Contact</a>
      {%- endif -%}
    </div>

    <div class="gg-drawer__footer">
      <div class="gg-drawer__cta-wrap">
        <a href="{{ section.settings.cta_url | default: routes.collections_url }}" class="gg-btn gg-btn--primary">
          <span class="gg-btn__label">{{ section.settings.cta_label | default: 'Shop Now' }}</span>
          <div class="gg-btn__bg"></div>
          <div class="gg-btn__outline"></div>
        </a>
      </div>
      {%- if section.settings.support_text != blank -%}
        <p class="gg-drawer__meta">{{ section.settings.support_text }}</p>
      {%- endif -%}
    </div>

  </nav>
</div>

<script>
  (function () {
    var nav      = document.getElementById('gg-nav');
    var burger   = document.getElementById('gg-burger');
    var drawer   = document.getElementById('gg-drawer');
    var backdrop = document.getElementById('gg-backdrop');
    var closeBtn = document.getElementById('gg-drawer-close');
    var lastY    = 0;
    var ticking  = false;

    function openMenu() {
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      burger.classList.add('is-active');
      burger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      burger.classList.remove('is-active');
      burger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    burger.addEventListener('click', function () {
      drawer.classList.contains('is-open') ? closeMenu() : openMenu();
    });
    backdrop.addEventListener('click', closeMenu);
    closeBtn.addEventListener('click', closeMenu);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeMenu();
    });

    /* --- Smart scroll: glass on scroll + hide on down / reveal on up --- */
    window.addEventListener('scroll', function () {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function () {
        var currentY = window.scrollY;
        nav.classList.toggle('scrolled', currentY > 40);
        if (currentY > 80) {
          if (currentY > lastY + 4)      { nav.classList.add('is-hidden'); }
          else if (currentY < lastY - 4) { nav.classList.remove('is-hidden'); }
        } else {
          nav.classList.remove('is-hidden');
        }
        lastY   = currentY;
        ticking = false;
      });
    }, { passive: true });
  })();
</script>

{% schema %}
{
  "name": "GG \u2013 Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Leave blank to use the GG mark + GarageGains wordmark"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button link"
    },
    {
      "type": "text",
      "id": "support_text",
      "label": "Drawer footer text",
      "default": "support@garagegains.com.au \u00b7 Mon\u2013Fri 9am\u20135pm AEST"
    }
  ]
}
{% endschema %}
